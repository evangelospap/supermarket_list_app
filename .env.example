# Local Spring backend
PORT=8787
DATABASE_URL=jdbc:postgresql://localhost:54329/supermarket
DATABASE_USERNAME=supermarket
DATABASE_PASSWORD=supermarket

# Generate a long random value before sharing this app outside local dev.
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-characters
# Refresh cookies are marked Secure automatically on HTTPS requests.
# Set true only if you want to force Secure cookies even on local HTTP.
COOKIE_SECURE=false

# Frontend build served by Spring after `npm run build`.
FRONTEND_DIST=../dist

# Legacy import from the old JSON backend. Keep false after the first import.
IMPORT_LEGACY_STATE=false
LEGACY_STATE_FILE=../data/supermarket-state.json

# Google OAuth. Fill these only after creating credentials in Google Cloud.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
